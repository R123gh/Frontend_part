{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm --prefix project-frontend install && npm --prefix project-backend install",
  "buildCommand": "npm --prefix project-frontend run build",
  "outputDirectory": "project-frontend/dist",
  "functions": {
    "api/**/*.js": {
      "maxDuration": 15,
      "includeFiles": [
        "project-backend/manuals/**"
      ]
    },
    "api/**/*.py": {
      "maxDuration": 60,
      "includeFiles": [
        "project-rag-python/backend/**"
      ],
      "excludeFiles": [
        "project-rag-python/backend/venv/**",
        "project-frontend/node_modules/**",
        "project-backend/node_modules/**",
        ".git/**",
        ".run/**"
      ]
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
