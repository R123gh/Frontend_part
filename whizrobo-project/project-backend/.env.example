PORT=5001
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/<database>?retryWrites=true&w=majority
JWT_SECRET=replace_with_a_strong_random_secret
# Preferred: full Flask endpoint URL
RAG_FLASK_URL=http://127.0.0.1:5000/api/query
RAG_FLASK_IMAGE_URL=http://127.0.0.1:5000/api/image-query
RAG_FLASK_OCR_URL=http://127.0.0.1:5000/api/ocr
RAG_FLASK_TTS_URL=http://127.0.0.1:5000/api/tts
RAG_FLASK_ROBOT_URL=http://127.0.0.1:5000/api/robot-query

# Optional legacy style (used only if RAG_FLASK_URL is not set)
# RAG_FLASK_BASE_URL=http://127.0.0.1:5000
# RAG_FLASK_ENDPOINT=/api/query
